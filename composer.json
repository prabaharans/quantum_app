{
    "name": "quantumphp/studio",
    "description": "QuantumPHP Studio - Advanced Quantum Circuit Simulator (MVC Architecture)",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "QuantumApp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "QuantumApp\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
